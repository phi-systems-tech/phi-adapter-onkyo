{
  "configSchema": {
    "factory": {
      "title": "Connection",
      "fields": [
        {
          "key": "host",
          "type": "Hostname",
          "label": "Host"
        },
        {
          "key": "iscpPort",
          "type": "Port",
          "label": "ISCP Port",
          "default": 60128
        },
        {
          "key": "pollIntervalMs",
          "type": "Integer",
          "label": "Poll interval",
          "default": 5000
        },
        {
          "key": "retryIntervalMs",
          "type": "Integer",
          "label": "Retry interval",
          "default": 10000
        }
      ]
    }
  },
  "capabilities": {
    "required": ["Host", "Port"],
    "optional": ["UsesRetryInterval"],
    "flags": ["None"],
    "factoryActions": [
      {
        "id": "probe",
        "label": "Test connection",
        "description": "Validate receiver reachability using the current config values.",
        "hasForm": false,
        "meta": {
          "placement": "card",
          "kind": "command",
          "requiresAck": true
        }
      }
    ],
    "instanceActions": [
      {
        "id": "settings",
        "label": "Settings",
        "description": "Update adapter settings.",
        "hasForm": true,
        "meta": {
          "placement": "card",
          "kind": "open_dialog",
          "requiresAck": true
        }
      },
      {
        "id": "probeCurrentInput",
        "label": "Probe current",
        "description": "Probe current input and refresh labels.",
        "hasForm": false,
        "meta": {
          "placement": "form_field",
          "kind": "command",
          "requiresAck": true,
          "reloadStaticConfig": true
        }
      }
    ]
  },
  "discovery": [
    {
      "kind": "mdns",
      "mdnsServiceType": "_sues800device._tcp",
      "defaultPort": 60128,
      "hints": {
        "portOverride": 60128,
        "portOverrideOnlyIfDiscoveredPortIn": [80]
      }
    },
    {
      "kind": "mdns",
      "mdnsServiceType": "_suegrouping._tcp",
      "defaultPort": 60128,
      "hints": {
        "portOverride": 60128,
        "portOverrideOnlyIfDiscoveredPortIn": [80]
      }
    }
  ]
}
